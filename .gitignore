# Build artifacts
build/
dist/
__pycache__/
*.pyc
*.pyo
*.egg-info/
eggs/
*.egg

# Runtime / data
.blop/
.vibetest/
runs/

# Claude Code local worktrees / agent state (not part of the project)
.claude/

# Ralph autonomous agent (local tooling, not part of the project)
.ralph/
.ralphrc
ralph-claude-code/

# Auth session files
auth_state*.json

# Environment files
.env
.venv/
venv/

# QA test artifacts
qa_artifacts/

# IDE files
.vscode/
.idea/
*.swp
*.swo

# Cursor — local editor state (never `git add .` secrets or scratch plans).
# Optional: commit only the template; real config stays untracked as `.cursor/mcp.json`.
.cursor/*
!.cursor/mcp.json.example

# Local uv cache (never commit)
.uv-cache/

# Keys and certs (accidental commit prevention)
*.pem
*.p12
*.key
id_rsa
id_rsa.pub
id_ed25519
id_ed25519.pub

# OS files
.DS_Store
Thumbs.db

# Logs
*.log

# Test cache
.pytest_cache/
.mypy_cache/
.ruff_cache/
htmlcov/
.coverage
coverage.xml

# SQLite databases (runtime data)
*.db
*.db-shm
*.db-wal
