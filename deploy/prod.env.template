# blop production env template (local managed stdio baseline)
# Copy to a secure location (for example /etc/blop/prod.env) and fill values.

# Environment mode
BLOP_ENV=production
BLOP_REQUIRE_ABSOLUTE_PATHS=true

# LLM provider and credentials (choose one provider)
BLOP_LLM_PROVIDER=google
GOOGLE_API_KEY=
# BLOP_LLM_PROVIDER=anthropic
# ANTHROPIC_API_KEY=
# BLOP_LLM_PROVIDER=openai
# OPENAI_API_KEY=

# Absolute storage/logging paths
BLOP_DB_PATH=/var/lib/blop/runs.db
BLOP_RUNS_DIR=/var/lib/blop/runs
BLOP_DEBUG_LOG=/var/log/blop/blop.log

# Tool-surface hardening
BLOP_CAPABILITIES_PROFILE=production_minimal
BLOP_ENABLE_COMPAT_TOOLS=false

# URL safety
BLOP_ALLOW_INTERNAL_URLS=false
# BLOP_ALLOWED_HOSTS=staging.example.com,app.example.com

# Runtime guardrails
BLOP_RUN_TIMEOUT_SECS=1800
BLOP_STEP_TIMEOUT_SECS=45
BLOP_MAX_CONCURRENT_RUNS=10

# Privacy
BLOP_ALLOW_SCREENSHOT_LLM=false
