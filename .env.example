# ─────────────────────────────────────────────────────────────────────────────
# blop configuration
# Copy this file to .env and fill in your values.
# Never commit your .env file to git — it contains secrets.
# ─────────────────────────────────────────────────────────────────────────────


# ── REQUIRED ─────────────────────────────────────────────────────────────────

# Your Google Gemini API key.
# Get a free one at: https://aistudio.google.com/app/apikey
# The free tier is enough to run blop.
GOOGLE_API_KEY=


# ── YOUR APP ─────────────────────────────────────────────────────────────────

# The URL of the app you want to test.
APP_BASE_URL=https://your-app.com

# The URL of your login page (only needed for testing authenticated flows).
LOGIN_URL=https://your-app.com/login


# ── LOGIN CREDENTIALS ────────────────────────────────────────────────────────
# Used when auth_type="env_login" in save_auth_profile.
# blop reads these at runtime — they are never stored in the database.
# Use a dedicated test account, not your personal login.

TEST_USERNAME=testuser@yourcompany.com
TEST_PASSWORD=your_test_password

# (Optional) Override the CSS selectors blop uses to find the login form fields.
# blop tries common selectors automatically, so you usually don't need these.
# Only set them if auto-detection fails for your login form.
# TEST_USERNAME_SELECTOR=input[name="email"]
# TEST_PASSWORD_SELECTOR=input[name="password"]


# ── SESSION / COOKIE AUTH ────────────────────────────────────────────────────
# Alternative auth methods for SSO, OAuth, or MFA flows.
# If you use Google Sign-In, Okta, or any login blop can't automate,
# log in manually in Chrome, export your session, and point blop at the file.

# Path to a Playwright storage_state.json file (exported browser session).
STORAGE_STATE_PATH=

# Path to a JSON file containing exported browser cookies.
COOKIE_JSON_PATH=


# ── STORAGE ──────────────────────────────────────────────────────────────────

# Where blop stores its database (recorded flows, runs, results).
# The folder will be created automatically if it doesn't exist.
BLOP_DB_PATH=.blop/runs.db

# Environment mode and config strictness.
# development = local defaults
# production  = stricter startup checks and path validation
# BLOP_ENV=development
# BLOP_REQUIRE_ABSOLUTE_PATHS=false


# ── BEHAVIOUR ────────────────────────────────────────────────────────────────

# Whether to run the browser visibly or in the background.
# true  = headless (faster, good for CI/CD)
# false = shows the browser window (good for debugging)
BLOP_HEADLESS=true

# Maximum number of steps the AI agent will take per flow.
# Increase this if your flows are long or complex.
BLOP_MAX_STEPS=50

# Privacy guard for visual regression LLM triage.
# false = never send baseline/current screenshots to external LLM providers.
# true  = allow screenshot bytes to be uploaded for "meaningful vs benign" triage.
# Default is false for safety.
BLOP_ALLOW_SCREENSHOT_LLM=false

# Optional: wrap LLM calls in OpenTelemetry spans (console export to stderr when blop-mcp[otel] is installed).
# BLOP_OTEL_TRACING=false

# URL safety defaults (SSRF guard):
# By default, internal/private hosts are blocked.
# Set true only for trusted local testing (localhost, private VPC hosts).
# BLOP_ALLOW_INTERNAL_URLS=false

# Optional explicit allowlist for app_url hostnames (comma-separated).
# If set, app_url host must match one of these values/subdomains.
# BLOP_ALLOWED_HOSTS=staging.example.com,app.example.com

# Exploration tuning profile.
# - default: balanced settings for typical apps
# - saas_marketing: better defaults for heavy async SPAs and cross-origin app handoffs
BLOP_EXPLORATION_PROFILE=default

# Agent robustness tuning (optional overrides; profile presets apply when unset).
# BLOP_AGENT_MAX_FAILURES=5
# BLOP_AGENT_MAX_ACTIONS_PER_STEP=6
# BLOP_DISCOVERY_MAX_PAGES=10

# Extra settle time in ms after SPA navigation (pushState / client-side routing).
# Seconds to wait for network idle after page load (good range: 2.0-5.0 for heavy editors).
# BLOP_NETWORK_IDLE_WAIT=2.0
# BLOP_SPA_SETTLE_MS=1500


# ── MULTI-LLM PROVIDER (optional) ────────────────────────────────────────────

# LLM provider for agents and planning. Default: google (Gemini).
# Options: google | anthropic | openai
# BLOP_LLM_PROVIDER=google

# Override the default model for the selected provider.
# Google default: gemini-2.5-flash
# Anthropic default: claude-3-5-sonnet-20241022 (agent), claude-3-5-haiku-20241022 (planning)
# OpenAI default: gpt-4o (agent), gpt-4o-mini (planning)
# BLOP_LLM_MODEL=

# Required when BLOP_LLM_PROVIDER=anthropic
# ANTHROPIC_API_KEY=

# Required when BLOP_LLM_PROVIDER=openai
# OPENAI_API_KEY=

# Enable Gemini extended thinking for complex app discovery (0 = disabled).
# Increases latency but improves flow quality for checkout-heavy / editor-heavy apps.
# BLOP_THINKING_BUDGET=0

# Guardrail timeouts (seconds)
# 0 means disabled for run timeout.
# BLOP_RUN_TIMEOUT_SECS=0
# BLOP_STEP_TIMEOUT_SECS=45


# ── STORAGE ARCHIVAL (optional) ──────────────────────────────────────────────

# Auto-archive runs older than this many days via blop_v2_archive_storage.
# BLOP_ARCHIVE_RUNS_AFTER_DAYS=30

# Auto-archive telemetry signals older than this many days.
# BLOP_ARCHIVE_TELEMETRY_AFTER_DAYS=90


# ── HTTP SSE SERVER (optional) ──────────────────────────────────────────────
# Only used when running `blop-http` (requires `pip install blop[server]`).

# Host for the HTTP server (default: 0.0.0.0).
# BLOP_HTTP_HOST=0.0.0.0

# Port for the HTTP server (default: 8765).
# BLOP_HTTP_PORT=8765

# Protect REST /v1 with a shared secret (Bearer or X-Blop-Api-Key).
# If unset, /v1 is open and the server logs a stderr warning at startup.
# BLOP_HTTP_API_KEY=

# Optional absolute base URL for link fields in JSON (reverse proxy / TLS offloading).
# BLOP_HTTP_PUBLIC_BASE_URL=https://blop.example.com


# ── ARTIFACTS ────────────────────────────────────────────────────────────────

# Directory for run artifacts (screenshots, traces, console logs).
# Relative to repo root. Default: runs
# BLOP_RUNS_DIR=runs

# Optional explicit debug log destination.
# In production, prefer an absolute path and centralized log collection.
# BLOP_DEBUG_LOG=/var/log/blop/blop.log

# Tool-surface gating (least privilege)
# core,auth,debug,analytics,v2,assertions,security,reporting,compat_browser
# Default in code: core,auth,debug
# BLOP_CAPABILITIES=core,auth

# Compat tool registration gate (legacy browser_* surface)
# Keep false in production unless explicitly required.
# BLOP_ENABLE_COMPAT_TOOLS=false

# Deprecated MCP tool names: discover_test_flows, run_regression_test, validate_setup.
# BLOP_ENABLE_LEGACY_MCP_TOOLS=false

# ── AUTO-HEAL (optional) ────────────────────────────────────────────────────
# Thresholds for the auto-heal step repair in regression replay.

# Minimum confidence required to accept an auto-healed selector (0.0-1.0).
# BLOP_AUTO_HEAL_MIN_CONFIDENCE=0.78

# Maximum acceptable behavior change risk for auto-healed steps (0.0-1.0).
# BLOP_AUTO_HEAL_MAX_BEHAVIOR_RISK=0.25


# ── MOBILE / APPIUM (optional extra: pip install blop-mcp[mobile]) ─────────────

# Local Appium 3 server (default). Ignored when using a cloud provider below.
# BLOP_APPIUM_URL=http://127.0.0.1:4723

# local | browserstack | lambdatest
# BLOP_MOBILE_PROVIDER=local

# BrowserStack Appium hub (when BLOP_MOBILE_PROVIDER=browserstack)
# BLOP_BS_USER=
# BLOP_BS_KEY=

# LambdaTest mobile hub (when BLOP_MOBILE_PROVIDER=lambdatest)
# BLOP_LT_USER=
# BLOP_LT_KEY=


# ── AUTH FALLBACK ────────────────────────────────────────────────────────────

# Fallback auth URL (used when LOGIN_URL is not set).
# TEST_AUTH_URL=


# ── DEBUG ────────────────────────────────────────────────────────────────────

# Enable debug logging to /tmp/blop_debug.log during recording.
# BLOP_DEBUG=


# ── HOSTED AI QA PLATFORM (blop repo) ─────────────────────────────────────────
# Optional: push run results to the FastAPI app (POST /api/v1/sync/runs).
# Set all three hosted sync values together, or leave all three unset for local-only mode.
# Clone: https://github.com/.../blop (ai-qa-platform apps/api).
#
# BLOP_HOSTED_URL=http://127.0.0.1:8000
# BLOP_API_TOKEN=   # blop_sk_… from dashboard or: poetry run python scripts/sync_local_smoke.py
# BLOP_PROJECT_ID=00000000-0000-0000-0000-000000000000
#
# When APP_BASE_URL or BLOP_HOSTED_URL is localhost, the SSRF guard blocks unless:
# BLOP_ALLOW_INTERNAL_URLS=true
